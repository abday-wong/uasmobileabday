{
	"info": {
		"_postman_id": "e81d7f6c-e5b1-4f1e-9ba4-e0b484556f8f",
		"name": "E-Money 2FA Testing",
		"description": "Koleksi API untuk pengujian Two-Factor Authentication (2FA) pada project E-Money.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Firebase Auth (External)",
			"item": [
				{
					"name": "1. Firebase Register Email & Password",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{USER_EMAIL}}\",\n    \"password\": \"{{USER_PASSWORD}}\",\n    \"returnSecureToken\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://identitytoolkit.googleapis.com/v1/accounts:signUp?key={{FIREBASE_API_KEY}}",
							"protocol": "https",
							"host": [
								"identitytoolkit",
								"googleapis",
								"com"
							],
							"path": [
								"v1",
								"accounts:signUp"
							],
							"query": [
								{
									"key": "key",
									"value": "{{FIREBASE_API_KEY}}"
								}
							]
						},
						"description": "Membuat user baru di Firebase Authentication menggunakan Email & Password."
					},
					"response": []
				},
				{
					"name": "2. Firebase Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.idToken) {",
									"    pm.environment.set(\"FIREBASE_ID_TOKEN\", jsonData.idToken);",
									"    console.log(\"Saved FIREBASE_ID_TOKEN to environment.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{USER_EMAIL}}\",\n    \"password\": \"{{USER_PASSWORD}}\",\n    \"returnSecureToken\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{FIREBASE_API_KEY}}",
							"protocol": "https",
							"host": [
								"identitytoolkit",
								"googleapis",
								"com"
							],
							"path": [
								"v1",
								"accounts:signInWithPassword"
							],
							"query": [
								{
									"key": "key",
									"value": "{{FIREBASE_API_KEY}}"
								}
							]
						},
						"description": "Login ke Firebase untuk mendapatkan FIREBASE_ID_TOKEN."
					},
					"response": []
				}
			]
		},
		{
			"name": "Authentication (Backend)",
			"item": [
				{
					"name": "GET /v1/auth/me",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{BACKEND_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BACKEND_BASE_URL}}/auth/me",
							"host": [
								"{{BACKEND_BASE_URL}}"
							],
							"path": [
								"auth",
								"me"
							]
						},
						"description": "Mengambil data profil user yang sedang login menggunakan token JWT backend."
					},
					"response": []
				},
				{
					"name": "PUT /v1/auth/fcm-token",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{BACKEND_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fcm_token\": \"mock_device_fcm_token_998877\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BACKEND_BASE_URL}}/auth/fcm-token",
							"host": [
								"{{BACKEND_BASE_URL}}"
							],
							"path": [
								"auth",
								"fcm-token"
							]
						},
						"description": "Mengupdate token FCM (Firebase Cloud Messaging) user ke database."
					},
					"response": []
				}
			]
		},
