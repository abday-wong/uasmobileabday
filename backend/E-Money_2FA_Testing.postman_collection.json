									"key": "token",
									"value": "{{BACKEND_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"recipient_email\": \"recipient@example.com\",\n    \"amount\": 25000\n}",
