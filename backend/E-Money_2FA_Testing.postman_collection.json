					"name": "POST /v1/otp/totp/verify",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{BACKEND_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BACKEND_BASE_URL}}/otp/totp/verify",
							"host": [
								"{{BACKEND_BASE_URL}}"
							],
							"path": [
								"otp",
								"totp",
								"verify"
							]
						},
						"description": "Kirimkan kode angka dari Google Authenticator untuk memverifikasi dan mengaktifkan 2FA TOTP di database."
					},
					"response": []
				}
