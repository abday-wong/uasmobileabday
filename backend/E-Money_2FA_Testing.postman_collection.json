		{
			"name": "Google Authenticator (TOTP)",
			"item": [
				{
					"name": "POST /v1/otp/totp/register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.secret) {",
									"    pm.environment.set(\"TOTP_SECRET\", jsonData.secret);",
									"    console.log(\"Saved TOTP SECRET: \" + jsonData.secret);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{BACKEND_TOKEN}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{BACKEND_BASE_URL}}/otp/totp/register",
							"host": [
								"{{BACKEND_BASE_URL}}"
							],
							"path": [
								"otp",
								"totp",
								"register"
							]
						},
						"description": "Mendaftarkan TOTP 2FA. Mengembalikan Secret Key untuk Google Authenticator."
					},
					"response": []
				},
